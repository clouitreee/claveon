---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---
<section class="section" id="ueber-uns" data-reveal style="background:var(--terra-light);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div style="max-width:380px;">
        <img src="/assets/martin.jpg" alt="ClaveON Team" loading="lazy"
          style="width:100%;border-radius:6px;aspect-ratio:4/5;object-fit:cover;object-position:top;display:block;" />
      </div>
      <div>
        <p style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--terra);margin-bottom:1rem;">
          {lang === 'de' ? '— Über uns' : '— About us'}
        </p>
        <h2 style="font-size:clamp(1.8rem,3.5vw,2.5rem);margin-bottom:1.5rem;">
          {lang === 'de' ? 'Kein Callcenter. Kein Konzern.' : 'No call center. No corporation.'}
        </h2>
        {lang === 'de' ? (
          <div style="display:grid;gap:1rem;color:var(--muted);font-size:1rem;line-height:1.7;">
            <p style="margin:0;">Wir sind ein kleines Team aus Köln — mit Leidenschaft für Technik und dem echten Wunsch, dass Ihre Geräte funktionieren.</p>
            <p style="margin:0;">Wir kommen persönlich zu Ihnen, erklären was wir tun, und gehen erst wenn das Problem gelöst ist.</p>
            <p style="margin:0;font-weight:600;color:var(--text);">Deutsch · Español · English</p>
          </div>
        ) : (
          <div style="display:grid;gap:1rem;color:var(--muted);font-size:1rem;line-height:1.7;">
            <p style="margin:0;">We are a small team from Cologne — passionate about technology and genuinely wanting your devices to work.</p>
            <p style="margin:0;">We come to you personally, explain what we do, and don't leave until the problem is solved.</p>
            <p style="margin:0;font-weight:600;color:var(--text);">Deutsch · Español · English</p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
<div class="divider"></div>

<style>
@media (max-width: 640px) {
  #ueber-uns .container > div { grid-template-columns: 1fr !important; }
  #ueber-uns img { max-width: 260px !important; }
}
</style>
