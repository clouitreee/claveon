---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---
<section class="section" id="ueber-uns" data-reveal style="background:var(--terra-light);">
  <div class="container">
    <div style="display:grid;grid-template-columns:auto 1fr;gap:3rem;align-items:center;">
      <div style="width:200px;flex-shrink:0;">
        <img src="/assets/martin.jpg" alt="ClaveON Team" loading="lazy"
          style="width:100%;border-radius:6px;aspect-ratio:1/1;object-fit:cover;object-position:top;display:block;" />
      </div>
      <div>
        <p style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--terra);margin-bottom:1rem;">
          {lang === 'de' ? '— Über uns' : '— About us'}
        </p>
        <h2 style="font-size:clamp(1.8rem,3.5vw,2.5rem);margin-bottom:1.5rem;">
          {lang === 'de' ? 'Kein Callcenter. Kein Konzern.' : 'No call center. No corporation.'}
        </h2>
        {lang === 'de' ? (
          <div style="display:grid;gap:1rem;color:var(--muted);font-size:1rem;line-height:1.7;">
            <p style="margin:0;">Martin repariert seit über 10 Jahren Geräte in Köln — ohne Fachjargon, ohne Callcenter. Nur echte Hilfe.</p>
            <p style="margin:0;">Er kommt persönlich zu Ihnen, erklärt jeden Schritt verständlich — und geht erst, wenn das Problem gelöst ist.</p>
            <p style="margin:0;font-weight:600;color:var(--text);">Deutsch · Español · English</p>
          </div>
        ) : (
          <div style="display:grid;gap:1rem;color:var(--muted);font-size:1rem;line-height:1.7;">
            <p style="margin:0;">Martin has been fixing devices in Cologne for over 10 years — no jargon, no call centre. Just real help.</p>
            <p style="margin:0;">He comes to you personally, explains every step clearly — and doesn't leave until the problem is solved.</p>
            <p style="margin:0;font-weight:600;color:var(--text);">Deutsch · Español · English</p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
<div class="divider"></div>

<style>
@media (min-width: 641px) and (max-width: 1024px) {
  #ueber-uns img { width: 160px !important; }
}
@media (max-width: 640px) {
  #ueber-uns .container > div { grid-template-columns: 1fr !important; }
  #ueber-uns img { width: 140px !important; }
}
</style>
