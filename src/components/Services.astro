---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
const t = {
  de: {
    label: '01 · Leistungen',
    headline: 'Wenn es Strom hat, schaue ich es mir an.',
    sub: 'Markenunabhängig. Erklärt in einfachem Deutsch.',
    services: [
      'PC & Laptop — langsam, Absturz, Viren, Neueinrichtung',
      'iPhone & Android — Einrichtung, Fotos sichern, Apps',
      'WLAN & Router — kein Internet, schwaches Signal, neuer Router',
      'Smart TV & Streaming — Netflix, Prime, Sender, Mediathek',
      'Drucker & Scanner — Installation, WLAN-Druck, Fehlermeldungen',
      'Kaffeevollautomat — Jura, DeLonghi, Siemens EQ · App & Einrichtung',
      'Saugroboter & Sprachassistenten — Roomba, Alexa, Google Home',
      'Passwörter & E-Mail — vergessen, neues Konto, Sicherheit',
      'Fotos & Backups — Übertragung, Cloud, externe Festplatte',
    ],
    last: 'Alles andere — wenn Sie unsicher sind, fragen Sie einfach.',
  },
  en: {
    label: '01 · Services',
    headline: "If it needs power, I'll take a look.",
    sub: 'Brand independent. Explained in plain language.',
    services: [
      'PC & Laptop — slow, crashes, viruses, fresh setup',
      'iPhone & Android — setup, photo backup, apps',
      'WiFi & Router — no internet, weak signal, new router',
      'Smart TV & Streaming — Netflix, Prime, channels, media',
      'Printer & Scanner — installation, wireless printing, errors',
      'Coffee machine — Jura, DeLonghi, Siemens EQ · app & setup',
      'Robot vacuum & voice assistants — Roomba, Alexa, Google Home',
      'Passwords & Email — forgotten, new account, security',
      'Photos & Backups — transfer, cloud, external drive',
    ],
    last: 'Anything else — if you\'re unsure, just ask.',
  }
};
const c = t[lang as keyof typeof t] ?? t.de;
---
<section class="section" id="leistungen" data-reveal>
  <div class="container">
    <div class="grid md:grid-cols-12 gap-10 items-start">

      <div class="md:col-span-3">
        <span class="font-mono text-xs tracking-widest uppercase" style="color: var(--muted);">{c.label}</span>
      </div>

      <div class="md:col-span-9">
        <h2 class="text-3xl md:text-4xl font-bold mb-3">{c.headline}</h2>
        <p class="text-base mb-8" style="color: var(--muted);">{c.sub}</p>

        <div class="space-y-3">
          {c.services.map(s => (
            <div class="flex items-start gap-3 py-3 border-b" style="border-color: var(--border);">
              <span class="mt-1 flex-shrink-0 font-mono text-sm" style="color: var(--blue);">→</span>
              <span class="text-base">{s}</span>
            </div>
          ))}
          <div class="flex items-start gap-3 py-3">
            <span class="mt-1 flex-shrink-0 font-mono text-sm" style="color: var(--muted);">→</span>
            <span class="text-base italic" style="color: var(--muted);">{c.last}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<div class="divider"></div>
