---

<section class="section" id="leistungen" data-reveal>
  <div class="container">
    <h2 style="font-size:clamp(2rem,4.5vw,3rem);margin-bottom:0.75rem;">{c.headline}</h2>
    <p style="color:var(--muted);margin-bottom:2.5rem;font-size:1rem;">{c.sub}</p>

    <div id="services-list">
      {c.services.map((s) => (
        <div class="svc-item" data-id={s.id} style="border-bottom:1px solid var(--border);">
          <!-- Header row (clickable) -->
          <button
            class="svc-header"
            aria-expanded="false"
            style="width:100%;display:flex;align-items:center;gap:1rem;padding:1.25rem 0;background:none;border:none;cursor:pointer;text-align:left;"
          >
            <span style="font-size:1.5rem;flex-shrink:0;line-height:1;">{s.icon}</span>
            <div style="flex:1;min-width:0;">
              <p style="font-weight:600;margin:0;font-size:1rem;color:var(--text);">{s.name}</p>
              <p style="color:var(--muted);margin:0;font-size:0.875rem;">{s.desc}</p>
            </div>
            <span class="svc-arrow" style="font-size:1rem;color:var(--terra);transition:transform 0.25s;flex-shrink:0;">↓</span>
          </button>

          <!-- Expandable panel -->
          <div class="svc-panel" style="display:none;padding-bottom:1.5rem;padding-left:2.5rem;">
            <div style="display:grid;gap:0.5rem;margin-bottom:1.25rem;">
              {s.steps.map((step, i) => (
                <div style="display:flex;align-items:flex-start;gap:0.75rem;">
                  <span style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;font-weight:700;color:var(--terra);flex-shrink:0;margin-top:0.2rem;min-width:1.25rem;">{i + 1}.</span>
                  <span style="font-size:0.95rem;color:var(--muted);line-height:1.5;">{step}</span>
                </div>
              ))}
            </div>
            <div style="display:flex;flex-wrap:wrap;align-items:center;gap:1.25rem;padding-top:1rem;border-top:1px solid var(--border);">
              <div style="display:flex;gap:1.5rem;flex-wrap:wrap;">
                <span style="font-size:0.85rem;color:var(--muted);display:flex;align-items:center;gap:0.4rem;">
                  <span style="font-family:'IBM Plex Mono',monospace;font-weight:700;color:var(--terra);">{s.price}</span>
                </span>
                <span style="font-size:0.85rem;color:var(--subtle);font-family:'IBM Plex Mono',monospace;">⏱ {s.time}</span>
              </div>
              <a href="#kontakt" class="btn-primary" style="font-size:0.85rem;padding:0.6rem 1.25rem;" data-svc={s.id}>
                {c.cta}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p style="margin-top:1.5rem;color:var(--subtle);font-style:italic;font-size:0.9rem;">→ {c.last}</p>
  </div>
</section>
<div class="divider"></div>

<script>
  document.querySelectorAll('.svc-header').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.svc-item') as HTMLElement;
      const panel = item.querySelector('.svc-panel') as HTMLElement;
      const arrow = btn.querySelector('.svc-arrow') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.svc-item').forEach(other => {
        if (other !== item) {
          const otherPanel = other.querySelector('.svc-panel') as HTMLElement;
          const otherBtn = other.querySelector('.svc-header') as HTMLElement;
          const otherArrow = other.querySelector('.svc-arrow') as HTMLElement;
          if (otherPanel) otherPanel.style.display = 'none';
          if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
          if (otherArrow) otherArrow.style.transform = 'rotate(0deg)';
          if (other instanceof HTMLElement) other.style.background = '';
        }
      });

      if (isOpen) {
        panel.style.display = 'none';
        btn.setAttribute('aria-expanded', 'false');
        arrow.style.transform = 'rotate(0deg)';
        item.style.background = '';
      } else {
        panel.style.display = 'block';
        btn.setAttribute('aria-expanded', 'true');
        arrow.style.transform = 'rotate(180deg)';
        item.style.background = 'var(--terra-light)';
        item.style.borderRadius = '6px';
        item.style.padding = '0 1rem';
        item.style.margin = '0 -1rem';
      }
    });
  });

  // CTA pre-fills contact form
  document.querySelectorAll('[data-svc]').forEach(link => {
    link.addEventListener('click', () => {
      const svcId = (link as HTMLElement).dataset.svc;
      const select = document.querySelector('[name="paket"]') as HTMLSelectElement;
      if (select && svcId) {
        // Map service id to paket option value
        const map: Record<string, string> = {
          pc: 'remote', handy: 'onsite', wlan: 'remote',
          tv: 'onsite', drucker: 'onsite', kaffee: 'onsite',
          smarthome: 'onsite', passwort: 'remote', fotos: 'remote',
          windows: 'migration',
        };
        select.value = map[svcId] ?? '';
      }
    });
  });
</script>
