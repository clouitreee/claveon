---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
const t = {
  de: {
    headline: 'Wenn es Strom hat, schauen wir es uns an.',
    sub: 'Markenunabhängig. Erklärt in einfachem Deutsch.',
    services: [
      { icon: '💻', name: 'PC & Laptop', desc: 'Langsam, Absturz, Viren, Neueinrichtung' },
      { icon: '📱', name: 'iPhone & Android', desc: 'Einrichtung, Fotos sichern, Apps, Updates' },
      { icon: '📡', name: 'WLAN & Router', desc: 'Kein Internet, schwaches Signal, neuer Router' },
      { icon: '📺', name: 'Smart TV & Streaming', desc: 'Netflix, Prime, ARD, Mediathek, Sender' },
      { icon: '🖨️', name: 'Drucker & Scanner', desc: 'Installation, WLAN-Druck, Fehlermeldungen' },
      { icon: '☕', name: 'Kaffeevollautomat', desc: 'Jura · DeLonghi · Siemens EQ — App & Einrichtung' },
      { icon: '🤖', name: 'Saugroboter & Smart Home', desc: 'Roomba, Alexa, Google Home, Philips Hue' },
      { icon: '🔑', name: 'Passwörter & E-Mail', desc: 'Vergessen, neues Konto, Sicherheit' },
      { icon: '📷', name: 'Fotos & Backups', desc: 'Übertragung, Cloud, externe Festplatte' },
      { icon: '🪟', name: 'Windows 10 → 11', desc: 'Upgrade-Beratung, Migration, Neugerät einrichten' },
    ],
    last: 'Alles andere — einfach fragen.',
  },
  en: {
    headline: "If it needs power, we'll take a look.",
    sub: 'Brand independent. Explained in plain language.',
    services: [
      { icon: '💻', name: 'PC & Laptop', desc: 'Slow, crashes, viruses, fresh setup' },
      { icon: '📱', name: 'iPhone & Android', desc: 'Setup, photo backup, apps, updates' },
      { icon: '📡', name: 'WiFi & Router', desc: 'No internet, weak signal, new router' },
      { icon: '📺', name: 'Smart TV & Streaming', desc: 'Netflix, Prime, channels, media library' },
      { icon: '🖨️', name: 'Printer & Scanner', desc: 'Installation, wireless printing, errors' },
      { icon: '☕', name: 'Coffee machine', desc: 'Jura · DeLonghi · Siemens EQ — app & setup' },
      { icon: '🤖', name: 'Robot vacuum & Smart Home', desc: 'Roomba, Alexa, Google Home, Philips Hue' },
      { icon: '🔑', name: 'Passwords & Email', desc: 'Forgotten, new account, security' },
      { icon: '📷', name: 'Photos & Backups', desc: 'Transfer, cloud, external drive' },
      { icon: '🪟', name: 'Windows 10 → 11', desc: 'Upgrade advice, migration, new device setup' },
    ],
    last: "Anything else — just ask.",
  }
};
const c = t[lang as keyof typeof t] ?? t.de;
---
<section class="section" id="leistungen" data-reveal>
  <div class="container">
    <h2 style="font-size:clamp(2rem,4.5vw,3rem);margin-bottom:0.75rem;">{c.headline}</h2>
    <p style="color:var(--muted);margin-bottom:3rem;font-size:1rem;">{c.sub}</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0;">
      {c.services.map((s) => (
        <div style="display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 0;border-bottom:1px solid var(--border);padding-right:1.5rem;">
          <span style="font-size:1.4rem;flex-shrink:0;line-height:1.4;">{s.icon}</span>
          <div>
            <p style="font-weight:600;margin:0 0 0.15rem;font-size:1rem;">{s.name}</p>
            <p style="color:var(--muted);margin:0;font-size:0.875rem;">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <p style="margin-top:1.5rem;color:var(--subtle);font-style:italic;font-size:0.9rem;">→ {c.last}</p>
  </div>
</section>
<div class="divider"></div>
