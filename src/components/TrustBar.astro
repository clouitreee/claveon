---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
const items = lang === 'de'
  ? ['Kein Minutentakt', 'Kein MediaMarkt-Preis', 'Köln & 15 km Umgebung', 'Nur per E-Mail — schnelle Antwort']
  : ['No per-minute billing', 'No MediaMarkt price', 'Cologne & 15 km area', 'Email only — fast reply'];
---
<section class="section-sm">
  <div class="container">
    <div class="flex flex-wrap gap-x-8 gap-y-3 justify-center md:justify-start">
      {items.map(item => (
        <div class="flex items-center gap-2 text-sm font-medium" style="color: var(--muted);">
          <span style="color: var(--green);">✓</span>
          {item}
        </div>
      ))}
    </div>
  </div>
</section>
<div class="divider"></div>
