---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;

const de = {
  headline: 'Was ist Ihr Problem?',
  sub: 'Wählen Sie aus — wir zeigen Ihnen den genauen Preis und die Zeit.',
  step1: { q: 'Für wen?', opts: [
    { id: 'privat', icon: '🏠', label: 'Für mich / Familie' },
    { id: 'firma',  icon: '🏢', label: 'Für mein Unternehmen' },
  ]},
  step2: { q: 'Welches Gerät?', opts: [
    { id: 'pc',    icon: '💻', label: 'PC / Laptop' },
    { id: 'handy', icon: '📱', label: 'Handy / Tablet' },
    { id: 'wlan',  icon: '📡', label: 'WLAN / Router' },
    { id: 'tv',    icon: '📺', label: 'TV / Drucker' },
    { id: 'other', icon: '🔧', label: 'Sonstiges' },
  ]},
  step3: {
    pc:    { q: 'Was ist das Problem?', opts: [{ id: 'slow', label: 'Läuft langsam / Abstürze' }, { id: 'virus', label: 'Viren / Fehlermeldungen' }, { id: 'setup', label: 'Neueinrichtung / Windows 11' }]},
    handy: { q: 'Was ist das Problem?', opts: [{ id: 'setup', label: 'Einrichtung / Apps' }, { id: 'photos', label: 'Fotos sichern / übertragen' }, { id: 'slow', label: 'Langsam / Speicher voll' }]},
    wlan:  { q: 'Was ist das Problem?', opts: [{ id: 'none', label: 'Kein Internet' }, { id: 'weak', label: 'Schwaches Signal' }, { id: 'new', label: 'Neuer Router einrichten' }]},
    tv:    { q: 'Was ist das Problem?', opts: [{ id: 'stream', label: 'Netflix / Streaming einrichten' }, { id: 'print', label: 'Drucker funktioniert nicht' }, { id: 'other', label: 'Sonstiges' }]},
    other: { q: 'Was brauchen Sie?', opts: [{ id: 'remote', label: 'Fernhilfe reicht' }, { id: 'onsite', label: 'Jemand soll vorbeikommen' }, { id: 'unsure', label: 'Ich bin nicht sicher' }]},
  },
  results: {
    remote:    { pkg: 'Fernwartung', price: '€29', unit: '/ 30 Min', how: 'Per Bildschirmübertragung — wir verbinden uns mit Ihrem Gerät.', time: '30 Minuten', note: 'Brauchen wir länger? Wir sagen es vorher — nie mehr ohne Ihre Zustimmung.', tv_link: true },
    onsite:    { pkg: 'Vor-Ort Hilfe', price: '€79', unit: '/ Einsatz', how: 'Wir kommen zu Ihnen — Köln & bis zu 15 km Umgebung.', time: 'Ca. 1 Stunde', note: 'Dauert es länger? Wir sprechen vorher darüber. Kein Konzernpreis.', tv_link: false },
    neustart:  { pkg: 'Neustart-Paket', price: '€89', unit: '/ Einsatz', how: 'Neues Gerät einrichten, Daten übertragen, WLAN verbinden.', time: 'Ca. 1,5–2 Stunden', note: 'Alles erklärt, alles eingerichtet. Kein Konzernpreis.', tv_link: false },
    migration: { pkg: 'Windows 10 → 11', price: '€99', unit: '/ Einsatz', how: 'Upgrade oder neues Gerät — komplett eingerichtet und erklärt.', time: 'Ca. 2 Stunden', note: 'Inkl. Datenmigration. Kein Konzernpreis.', tv_link: false },
  },
  werixo: 'Für Unternehmens-IT empfehlen wir WERIXO — professioneller Managed Service für KMU.',
  werixoCta: 'werixo.de besuchen ↗',
  tvTitle: 'Schritt 1 — TeamViewer herunterladen:',
  tvSub: 'Starten Sie TeamViewer, teilen Sie uns die ID + das angezeigte Passwort mit.',
  cta: 'Jetzt anfragen →',
  back: '← Zurück',
  fallback: 'Stundensatz: €59/h — transparent, kein Minutentakt.',
};
const en = {
  headline: "What's your problem?",
  sub: 'Select below — we show you the exact price and time.',
  step1: { q: 'Who is this for?', opts: [{ id: 'privat', icon: '🏠', label: 'For me / family' }, { id: 'firma', icon: '🏢', label: 'For my business' }]},
  step2: { q: 'Which device?', opts: [{ id: 'pc', icon: '💻', label: 'PC / Laptop' }, { id: 'handy', icon: '📱', label: 'Phone / Tablet' }, { id: 'wlan', icon: '📡', label: 'WiFi / Router' }, { id: 'tv', icon: '📺', label: 'TV / Printer' }, { id: 'other', icon: '🔧', label: 'Other' }]},
  step3: {
    pc:    { q: "What's the issue?", opts: [{ id: 'slow', label: 'Running slow / crashes' }, { id: 'virus', label: 'Viruses / error messages' }, { id: 'setup', label: 'Fresh setup / Windows 11' }]},
    handy: { q: "What's the issue?", opts: [{ id: 'setup', label: 'Setup / apps' }, { id: 'photos', label: 'Backup / transfer photos' }, { id: 'slow', label: 'Slow / storage full' }]},
    wlan:  { q: "What's the issue?", opts: [{ id: 'none', label: 'No internet' }, { id: 'weak', label: 'Weak signal' }, { id: 'new', label: 'New router setup' }]},
    tv:    { q: "What's the issue?", opts: [{ id: 'stream', label: 'Netflix / streaming setup' }, { id: 'print', label: "Printer not working" }, { id: 'other', label: 'Other' }]},
    other: { q: 'What do you need?', opts: [{ id: 'remote', label: 'Remote help is enough' }, { id: 'onsite', label: 'Someone should come over' }, { id: 'unsure', label: "I'm not sure" }]},
  },
  results: {
    remote:    { pkg: 'Remote Support', price: '€29', unit: '/ 30 min', how: 'Via screen sharing — we connect to your device.', time: '30 minutes', note: 'Need more time? We tell you first — never more without your approval.', tv_link: true },
    onsite:    { pkg: 'On-site Help', price: '€79', unit: '/ visit', how: 'We come to you — Cologne & up to 15 km area.', time: 'Approx. 1 hour', note: 'Takes longer? We discuss it first. No corporate pricing.', tv_link: false },
    neustart:  { pkg: 'Fresh Start Package', price: '€89', unit: '/ visit', how: 'Set up new device, transfer data, connect WiFi.', time: 'Approx. 1.5–2 hours', note: 'Everything set up and explained. No corporate pricing.', tv_link: false },
    migration: { pkg: 'Windows 10 → 11', price: '€99', unit: '/ visit', how: 'Upgrade or new device — fully set up and explained.', time: 'Approx. 2 hours', note: 'Includes data migration. No corporate pricing.', tv_link: false },
  },
  werixo: 'For business IT we recommend WERIXO — professional Managed Service for SMEs.',
  werixoCta: 'Visit werixo.de ↗',
  tvTitle: 'Step 1 — Download TeamViewer:',
  tvSub: 'Start TeamViewer and share your ID + the displayed password with us.',
  cta: 'Request now →',
  back: '← Back',
  fallback: 'Hourly rate: €59/h — transparent, no per-minute billing.',
};
const c = lang === 'en' ? en : de;
---

<section class="section" id="assistent" data-reveal style="background:var(--bg-soft);">
  <div class="container">
    <h2 style="font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:0.5rem;">{c.headline}</h2>
    <p style="color:var(--muted);margin-bottom:2rem;font-size:1rem;">{c.sub}</p>

    <div id="step-indicator" style="display:flex;gap:0.5rem;margin-bottom:2rem;align-items:center;">
      <span id="dot-1" style="width:8px;height:8px;border-radius:50%;background:var(--terra);transition:background 0.2s;"></span>
      <span id="dot-2" style="width:8px;height:8px;border-radius:50%;background:var(--border);transition:background 0.2s;"></span>
      <span id="dot-3" style="width:8px;height:8px;border-radius:50%;background:var(--border);transition:background 0.2s;"></span>
    </div>

    <div id="step-1">
      <p style="font-family:'IBM Plex Mono',monospace;font-size:0.85rem;letter-spacing:0.05em;color:var(--muted);margin-bottom:1rem;">{c.step1.q}</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.75rem;">
        {c.step1.opts.map(o => (
          <button class="tile" data-step="1" data-val={o.id}><span class="tile-icon">{o.icon}</span><span>{o.label}</span></button>
        ))}
      </div>
    </div>

    <div id="step-2" style="display:none;">
      <p style="font-family:'IBM Plex Mono',monospace;font-size:0.85rem;letter-spacing:0.05em;color:var(--muted);margin-bottom:1rem;">{c.step2.q}</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:0.75rem;">
        {c.step2.opts.map(o => (
          <button class="tile" data-step="2" data-val={o.id}><span class="tile-icon">{o.icon}</span><span>{o.label}</span></button>
        ))}
      </div>
      <button id="back-1" style="margin-top:1.25rem;background:none;border:none;cursor:pointer;font-size:0.875rem;color:var(--muted);font-family:'IBM Plex Sans',sans-serif;">{c.back}</button>
    </div>

    <div id="step-3" style="display:none;">
      <p id="step3-q" style="font-family:'IBM Plex Mono',monospace;font-size:0.85rem;letter-spacing:0.05em;color:var(--muted);margin-bottom:1rem;"></p>
      <div id="step3-opts" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;"></div>
      <button id="back-2" style="margin-top:1.25rem;background:none;border:none;cursor:pointer;font-size:0.875rem;color:var(--muted);font-family:'IBM Plex Sans',sans-serif;">{c.back}</button>
    </div>

    <div id="result" style="display:none;"></div>
    <div id="werixo-block" style="display:none;" class="result-card">
      <p style="font-size:1rem;color:var(--muted);margin-bottom:1.25rem;">{c.werixo}</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
        <a href="https://werixo.de" target="_blank" rel="noopener" class="btn-primary">{c.werixoCta}</a>
        <button id="back-werixo" style="background:none;border:none;cursor:pointer;font-size:0.875rem;color:var(--muted);font-family:'IBM Plex Sans',sans-serif;">{c.back}</button>
      </div>
    </div>
    <p style="margin-top:2.5rem;font-size:0.85rem;color:var(--subtle);font-family:'IBM Plex Mono',monospace;">→ {c.fallback}</p>
  </div>
</section>
<div class="divider"></div>

<script define:vars={{ c, lang }}>
  const show = (id) => {
    ['step-1','step-2','step-3','result','werixo-block'].forEach(i => {
      const el = document.getElementById(i);
      if (el) el.style.display = 'none';
    });
    const target = document.getElementById(id);
    if (target) target.style.display = 'block';
  };
  const setDots = (active) => {
    [1,2,3].forEach(i => {
      const d = document.getElementById('dot-'+i);
      if (d) d.style.background = i <= active ? 'var(--terra)' : 'var(--border)';
    });
  };
  const resultKey = (dev, prob) => {
    if (dev === 'pc' && prob === 'setup') return 'migration';  // W10→11 €99
    if (dev === 'pc') return 'remote';                          // slow/virus €29
    if (dev === 'handy') return 'onsite';                       // phone = vor Ort €79
    if (dev === 'wlan' && prob === 'new') return 'onsite';      // new router €79
    if (dev === 'wlan') return 'remote';                        // fix WLAN €29
    if (dev === 'tv') return 'onsite';                          // €79
    if (prob === 'remote') return 'remote';
    if (prob === 'onsite') return 'onsite';
    return 'onsite';
  };
  const showResult = (key) => {
    const r = c.results[key] || c.results['onsite'];
    const tvHtml = r.tv_link ? `
      <div style="margin:1.25rem 0;padding:1rem;background:#fff;border-radius:4px;border:1px solid var(--border);">
        <p style="font-family:'IBM Plex Mono',monospace;font-size:0.8rem;color:var(--muted);margin-bottom:0.75rem;">${c.tvTitle}</p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="https://download.teamviewer.com/download/TeamViewer_Setup.exe" style="font-family:'IBM Plex Mono',monospace;font-size:0.8rem;padding:0.5rem 1rem;border:1.5px solid var(--border);border-radius:4px;text-decoration:none;color:var(--text);">⬇ Windows</a>
          <a href="https://download.teamviewer.com/download/TeamViewer.dmg" style="font-family:'IBM Plex Mono',monospace;font-size:0.8rem;padding:0.5rem 1rem;border:1.5px solid var(--border);border-radius:4px;text-decoration:none;color:var(--text);">⬇ macOS</a>
        </div>
        <p style="font-size:0.8rem;color:var(--muted);margin-top:0.5rem;margin-bottom:0;">${c.tvSub}</p>
      </div>` : '';
    const resultEl = document.getElementById('result');
    resultEl.innerHTML = `
      <div class="result-card">
        <div style="display:flex;align-items:baseline;gap:0.75rem;margin-bottom:0.25rem;">
          <span style="font-family:'IBM Plex Mono',monospace;font-size:2.25rem;font-weight:700;color:var(--terra);letter-spacing:-0.04em;">${r.price}</span>
          <span style="font-size:0.9rem;color:var(--muted);">${r.unit}</span>
        </div>
        <h3 style="font-size:1.3rem;margin:0 0 0.5rem;">${r.pkg}</h3>
        <p style="margin:0 0 0.25rem;font-size:0.95rem;color:var(--muted);">${r.how}</p>
        <p style="margin:0 0 0.75rem;font-size:0.875rem;color:var(--subtle);font-family:'IBM Plex Mono',monospace;">⏱ ${r.time}</p>
        ${tvHtml}
        <p style="font-size:0.85rem;color:var(--green);margin-bottom:1.5rem;font-weight:500;">✓ ${r.note}</p>
        <a href="#kontakt" class="btn-primary" id="result-cta" data-pkg="${key}">${c.cta}</a>
      </div>
      <button id="back-3" style="margin-top:1rem;background:none;border:none;cursor:pointer;font-size:0.875rem;color:var(--muted);font-family:'IBM Plex Sans',sans-serif;">${c.back}</button>
    `;
    show('result');
    setDots(3);
    document.getElementById('result-cta')?.addEventListener('click', () => {
      const sel = document.querySelector('[name="paket"]');
      if (sel) sel.value = key;
    });
    document.getElementById('back-3')?.addEventListener('click', () => { show('step-3'); setDots(2); });
  };
  const renderStep3 = (dev) => {
    const step = c.step3[dev] || c.step3['other'];
    document.getElementById('step3-q').textContent = step.q;
    document.getElementById('step3-opts').innerHTML = step.opts.map(o =>
      `<button class="tile" data-step="3" data-val="${o.id}" data-dev="${dev}" style="flex-direction:row;justify-content:flex-start;padding:1rem 1.25rem;font-size:0.95rem;">${o.label}</button>`
    ).join('');
    document.querySelectorAll('[data-step="3"]').forEach(btn => {
      btn.addEventListener('click', () => showResult(resultKey(btn.dataset.dev, btn.dataset.val)));
    });
    show('step-3'); setDots(2);
  };
  document.querySelectorAll('[data-step="1"]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.dataset.val === 'firma') { show('werixo-block'); setDots(1); }
      else { show('step-2'); setDots(2); }
    });
  });
  document.querySelectorAll('[data-step="2"]').forEach(btn => {
    btn.addEventListener('click', () => renderStep3(btn.dataset.val));
  });
  document.getElementById('back-1')?.addEventListener('click', () => { show('step-1'); setDots(1); });
  document.getElementById('back-2')?.addEventListener('click', () => { show('step-2'); setDots(2); });
  document.getElementById('back-werixo')?.addEventListener('click', () => { show('step-1'); setDots(1); });
</script>
