---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
const t = {
  de: {
    headline: 'Schreiben Sie kurz, was los ist.',
    sub: 'Martin meldet sich innerhalb von 24 Stunden.',
    typePrivat: 'Privat',
    typeUnternehmen: 'Unternehmen',
    werixoText: 'Für IT-Infrastruktur von Unternehmen empfehlen wir WERIXO — professioneller Managed Service mit Monitoring, Backups und vierteljährlichem Evidence Pack.',
    werixoCta: 'werixo.de besuchen ↗',
    nameLabel: 'Ihr Name', emailLabel: 'E-Mail-Adresse',
    phoneLabel: 'Telefon (optional)', phonePlaceholder: '+49 ...',
    paketLabel: 'Worum geht es? (optional)',
    paketOptions: [
      { value: '', label: '— kein bestimmtes —' },
      { value: 'remote', label: 'Fernwartung · €29 / 30 Min' },
      { value: 'onsite', label: 'Vor-Ort Hilfe · €79' },
      { value: 'neustart', label: 'Neustart-Paket · €89' },
      { value: 'migration', label: 'Windows 10 → 11 · €99' },
      { value: 'other', label: 'Sonstiges · €59/h' },
    ],
    msgLabel: 'Ihre Nachricht', msgPlaceholder: 'z.B.: Seit gestern startet mein PC sehr langsam und friert manchmal ein.',
    submit: 'Nachricht senden', sending: 'Wird gesendet…',
    success: '✓ Nachricht gesendet. Wir melden uns bald.',
    error: 'Fehler beim Senden. Bitte direkt an info@claveon.de schreiben.',
    consentLabel: 'Ich akzeptiere die',
    consentLink: 'Datenschutzerklärung',
    consentSuffix: 'und stimme zu, dass meine Daten zur Bearbeitung meiner Anfrage verwendet werden.',
    datenschutzHref: '/datenschutz/',
  },
  en: {
    headline: "Tell us what isn't working.",
    sub: 'Martin replies within 24 hours.',
    typePrivat: 'Personal',
    typeUnternehmen: 'Business',
    werixoText: 'For business IT infrastructure we recommend WERIXO — professional Managed Service with monitoring, backups and quarterly Evidence Pack.',
    werixoCta: 'Visit werixo.de ↗',
    nameLabel: 'Your name', emailLabel: 'Email address',
    phoneLabel: 'Phone (optional)', phonePlaceholder: '+49 ...',
    paketLabel: 'What is it about? (optional)',
    paketOptions: [
      { value: '', label: '— no specific package —' },
      { value: 'remote', label: 'Remote Support · €29 / 30 min' },
      { value: 'onsite', label: 'On-site Help · €79' },
      { value: 'neustart', label: 'Fresh Start · €89' },
      { value: 'migration', label: 'Windows 10 → 11 · €99' },
      { value: 'other', label: 'Other · €59/h' },
    ],
    msgLabel: 'Your message', msgPlaceholder: 'e.g.: My PC has been very slow since yesterday and sometimes freezes.',
    submit: 'Send message', sending: 'Sending…',
    success: "✓ Message sent. We'll get back to you soon.",
    error: 'Error sending. Please write directly to info@claveon.de.',
    consentLabel: 'I accept the',
    consentLink: 'Privacy Policy',
    consentSuffix: 'and agree that my data will be used to process my request.',
    datenschutzHref: '/en/datenschutz/',
  }
};
const c = t[lang as keyof typeof t] ?? t.de;
---
<section class="section" id="kontakt" data-reveal>
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:3rem;align-items:start;">
      <div>
        <p style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--terra);margin-bottom:1rem;">
          {lang === 'de' ? '— Kontakt' : '— Contact'}
        </p>
        <h2 style="font-size:clamp(1.8rem,3.5vw,2.8rem);margin-bottom:1rem;">{c.headline}</h2>
        <p style="color:var(--muted);font-size:1rem;margin-bottom:2rem;">{c.sub}</p>
        <a href="mailto:info@claveon.de" style="font-family:'IBM Plex Mono',monospace;font-size:0.9rem;color:var(--terra);text-decoration:none;display:flex;align-items:center;gap:0.5rem;">✉ info@claveon.de</a>
      </div>
      <div>
        <div style="display:flex;gap:0.5rem;margin-bottom:1.5rem;">
          <button id="btn-privat" class="btn-primary" style="font-size:0.85rem;padding:0.6rem 1.25rem;">{c.typePrivat}</button>
          <button id="btn-unternehmen" class="btn-ghost" style="font-size:0.85rem;padding:0.6rem 1.25rem;">{c.typeUnternehmen}</button>
        </div>
        <div id="werixo-block" style="display:none;padding:1.5rem;background:var(--bg-soft);border:2px solid var(--border);border-radius:6px;margin-bottom:1rem;">
          <p style="color:var(--muted);font-size:0.95rem;margin-bottom:1.25rem;">{c.werixoText}</p>
          <a href="https://werixo.de" target="_blank" rel="noopener" class="btn-primary">{c.werixoCta}</a>
        </div>
        <form id="contact-form" style="display:grid;gap:1rem;" autocomplete="on">
          {/* Honeypot — invisible para humanos, los bots lo rellenan */}
          <div style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
            <label for="website">Website</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div>
            <label style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.4rem;">{c.nameLabel} *</label>
            <input name="name" required type="text" class="field" placeholder="Anna Müller" />
          </div>
          <div class="form-row-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.4rem;">{c.emailLabel} *</label>
              <input name="email" required type="email" class="field" placeholder="ihre@email.de" />
            </div>
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.4rem;">{c.phoneLabel}</label>
              <input name="phone" type="tel" class="field" placeholder={c.phonePlaceholder} />
            </div>
          </div>
          <div>
            <label style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.4rem;">{c.paketLabel}</label>
            <select name="paket" class="field" style="background:var(--bg);cursor:pointer;">
              {c.paketOptions.map(opt => <option value={opt.value}>{opt.label}</option>)}
            </select>
          </div>
          <div>
            <label style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.4rem;">{c.msgLabel} *</label>
            <textarea name="message" required rows={4} class="field" style="resize:none;" placeholder={c.msgPlaceholder}></textarea>
          </div>
          <div>
            <label style="display:flex;align-items:flex-start;gap:0.6rem;font-size:0.85rem;color:var(--muted);cursor:pointer;line-height:1.4;">
              <input name="consent" type="checkbox" required style="width:20px;height:20px;min-width:20px;margin-top:0.15rem;accent-color:var(--terra);flex-shrink:0;cursor:pointer;" />
              <span>
                {c.consentLabel}&nbsp;<a href={c.datenschutzHref} target="_blank" rel="noopener" style="color:var(--terra);text-decoration:underline;">{c.consentLink}</a>&nbsp;{c.consentSuffix}
              </span>
            </label>
          </div>
          <div id="form-status" style="display:none;font-size:0.9rem;font-weight:500;" role="alert" aria-live="polite"></div>
          <button type="submit" id="submit-btn" class="btn-primary" data-submit={c.submit} data-sending={c.sending}>{c.submit}</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
@media (max-width: 640px) {
  #kontakt .container > div { grid-template-columns: 1fr !important; gap: 2rem !important; }
  #contact-form .form-row-2col { grid-template-columns: 1fr !important; }
}
</style>

<script define:vars={{ successMsg: c.success, errorMsg: c.error }}>
  const btnPrivat = document.getElementById('btn-privat');
  const btnUnternehmen = document.getElementById('btn-unternehmen');
  const werixoBlock = document.getElementById('werixo-block');
  const contactForm = document.getElementById('contact-form');
  const setActive = (active) => {
    if (active === 'unternehmen') {
      werixoBlock.style.display = 'block'; contactForm.style.display = 'none';
      btnUnternehmen.className = 'btn-primary'; btnPrivat.className = 'btn-ghost';
    } else {
      werixoBlock.style.display = 'none'; contactForm.style.display = 'grid';
      btnPrivat.className = 'btn-primary'; btnUnternehmen.className = 'btn-ghost';
    }
    [btnPrivat, btnUnternehmen].forEach(b => { b.style.fontSize='0.85rem'; b.style.padding='0.6rem 1.25rem'; });
  };
  btnPrivat.addEventListener('click', () => setActive('privat'));
  btnUnternehmen.addEventListener('click', () => setActive('unternehmen'));
  contactForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');
    const formData = new FormData(contactForm);
    // Honeypot check — si tiene valor es un bot
    if (formData.get('website')) return;
    const { website: _hp, consent: _c, ...data } = Object.fromEntries(formData);
    btn.disabled = true; btn.textContent = btn.dataset.sending; status.style.display = 'none';
    try {
      const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (res.ok) { status.textContent = successMsg; status.style.color = 'var(--green)'; contactForm.reset(); }
      else throw new Error();
    } catch { status.textContent = errorMsg; status.style.color = '#DC2626'; }
    finally { status.style.display = 'block'; btn.disabled = false; btn.textContent = btn.dataset.submit; }
  });
</script>
