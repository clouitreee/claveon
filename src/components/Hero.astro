---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---

<section style="padding:5rem 0 0;border-bottom:1px solid var(--border);">
  <div class="container">

    <!-- Label -->
    <p class="anim-1" style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);margin-bottom:2.5rem;">
      {lang === 'de' ? '— Technikhilfe · Köln & Umgebung' : '— Tech Help · Cologne & surroundings'}
    </p>

    <!-- Big headline -->
    <h1 class="anim-2" style="font-size:clamp(3.5rem,10vw,7rem);line-height:1;letter-spacing:-0.03em;margin-bottom:0;color:var(--text);max-width:18ch;">
      {lang === 'de'
        ? <Fragment>Technik&shy;probleme?<br/><em style="font-style:normal;color:var(--terra);">Wir lösen sie.</em></Fragment>
        : <Fragment>Tech problems?<br/><em style="font-style:normal;color:var(--terra);">We fix them.</em></Fragment>
      }
    </h1>

    <!-- CTA row -->
    <div class="anim-3" style="display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;margin-top:3rem;padding-top:2.5rem;border-top:1px solid var(--border);">
      <a href="#assistent" class="btn-primary" style="font-size:1rem;padding:0.9rem 2rem;">
        {lang === 'de' ? 'Was kostet mein Problem? →' : 'What does my problem cost? →'}
      </a>
      <p style="font-size:0.9rem;color:var(--muted);margin:0;">
        {lang === 'de' ? 'Kein Konzernpreis. Kein Minutentakt.' : 'No corporate price. No per-minute billing.'}
      </p>
    </div>
  </div>

  <!-- Price band -->
  <div class="anim-4 price-band" style="background:var(--terra);margin-top:4rem;">
    <div class="container">
      <div class="price-band-inner">
        <div class="price-item price-item--bordered">
          <span class="price-num">€29</span>
          <span class="price-label">{lang === 'de' ? 'Fernwartung / 30 Min' : 'Remote / 30 min'}</span>
        </div>
        <div class="price-item price-item--bordered">
          <span class="price-num">€79</span>
          <span class="price-label">{lang === 'de' ? 'Vor Ort / Einsatz' : 'On-site / visit'}</span>
        </div>
        <div class="price-item">
          <span class="price-num">€99</span>
          <span class="price-label">Windows 10 → 11</span>
        </div>
      </div>
    </div>
  </div>

</section>

<style>
.price-band-inner {
  display: flex;
  flex-wrap: wrap;
}
.price-item {
  padding: 1.5rem 2.5rem 1.5rem 0;
  margin-right: 2.5rem;
}
.price-item--bordered {
  border-right: 1px solid rgba(255,255,255,0.2);
}
.price-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.04em;
}
.price-label {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.75);
  margin-left: 0.5rem;
}

@media (max-width: 640px) {
  .price-band-inner {
    flex-direction: column;
    gap: 0;
  }
  .price-item {
    padding: 1rem 0;
    margin-right: 0;
    border-right: none !important;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .price-item:last-child { border-bottom: none; }
  .price-num { font-size: 1.6rem; }
  .price-label { display: block; margin-left: 0; margin-top: 0.15rem; font-size: 0.8rem; }
}
</style>
