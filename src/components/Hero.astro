---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---
<section style="padding:5rem 0 4rem;border-bottom:1px solid var(--border);">
  <div class="container">
    <p class="anim-1" style="font-family:'IBM Plex Mono',monospace;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--terra);margin-bottom:1.5rem;">
      {lang === 'de' ? '— Technikhilfe · Köln & Umgebung' : '— Tech Help · Cologne & surroundings'}
    </p>
    <h1 class="anim-2" style="font-size:clamp(2.8rem,7vw,5.5rem);margin-bottom:0;color:var(--text);max-width:14ch;">
      {lang === 'de'
        ? <Fragment>Technik&shy;probleme?<br/><span style="color:var(--terra);">Wir lösen sie.</span></Fragment>
        : <Fragment>Tech problems?<br/><span style="color:var(--terra);">We fix them.</span></Fragment>
      }
    </h1>
    <div class="anim-3" style="display:flex;flex-wrap:wrap;gap:2rem;margin-top:2.5rem;margin-bottom:2.5rem;padding:1.5rem 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:2.5rem;font-weight:700;color:var(--terra);letter-spacing:-0.04em;">€25</span>
        <span style="font-size:0.9rem;color:var(--muted);margin-left:0.4rem;">{lang === 'de' ? 'Fernwartung / 30 Min' : 'Remote / 30 min'}</span>
      </div>
      <div style="width:1px;background:var(--border);align-self:stretch;" class="hidden sm:block"></div>
      <div>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:2.5rem;font-weight:700;color:var(--text);letter-spacing:-0.04em;">€49</span>
        <span style="font-size:0.9rem;color:var(--muted);margin-left:0.4rem;">{lang === 'de' ? 'Vor Ort / Einsatz' : 'On-site / visit'}</span>
      </div>
    </div>
    <div class="anim-4" style="display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;">
      <a href="#assistent" class="btn-primary" style="font-size:1rem;">
        {lang === 'de' ? 'Was kostet mein Problem? →' : 'What does my problem cost? →'}
      </a>
      <p style="font-size:0.9rem;color:var(--muted);margin:0;">
        {lang === 'de' ? 'Kein Konzernpreis. Kein Minutentakt.' : 'No corporate price. No per-minute billing.'}
      </p>
    </div>
    <div class="anim-5" style="display:flex;flex-wrap:wrap;gap:1.5rem;margin-top:3rem;">
      {(lang === 'de'
        ? ['PC · Mac · WLAN · TV · Drucker', 'Köln & 15 km Umgebung', 'Antwort in 24h', 'Deutsch · Español · English']
        : ['PC · Mac · WiFi · TV · Printer', 'Cologne & 15 km area', 'Reply within 24h', 'Deutsch · Español · English']
      ).map(item => (
        <span style="font-size:0.85rem;color:var(--subtle);display:flex;align-items:center;gap:0.4rem;">
          <span style="color:var(--green);font-weight:700;">✓</span> {item}
        </span>
      ))}
    </div>
  </div>
</section>
