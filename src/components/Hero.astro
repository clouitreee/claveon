---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---

<section style="padding:6rem 0 5rem;border-bottom:1px solid var(--border);">
  <div class="container" style="max-width:780px;">
    <p class="anim-1" style="font-family:'IBM Plex Mono',monospace;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--terra);margin-bottom:2rem;">
      {lang === 'de' ? '— Technikhilfe · Köln & Umgebung' : '— Tech Help · Cologne & surroundings'}
    </p>
    <h1 class="anim-2" style="font-size:clamp(3rem,8vw,5.5rem);margin-bottom:0;color:var(--text);line-height:1.05;letter-spacing:-0.02em;">
      {lang === 'de'
        ? <Fragment>Technik&shy;probleme?<br/><span style="color:var(--terra);">Wir lösen sie.</span></Fragment>
        : <Fragment>Tech problems?<br/><span style="color:var(--terra);">We fix them.</span></Fragment>
      }
    </h1>
    <div class="anim-3" style="display:flex;flex-wrap:wrap;gap:2.5rem;margin-top:3rem;margin-bottom:3rem;padding:2rem 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:2.75rem;font-weight:700;color:var(--terra);letter-spacing:-0.04em;">€29</span>
        <span style="font-size:0.9rem;color:var(--muted);margin-left:0.5rem;">{lang === 'de' ? 'Fernwartung / 30 Min' : 'Remote / 30 min'}</span>
      </div>
      <div style="width:1px;background:var(--border);align-self:stretch;" class="hidden sm:block"></div>
      <div>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:2.75rem;font-weight:700;color:var(--text);letter-spacing:-0.04em;">€79</span>
        <span style="font-size:0.9rem;color:var(--muted);margin-left:0.5rem;">{lang === 'de' ? 'Vor Ort / Einsatz' : 'On-site / visit'}</span>
      </div>
    </div>
    <div class="anim-4" style="display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;">
      <a href="#assistent" class="btn-primary" style="font-size:1rem;padding:0.9rem 2rem;">
        {lang === 'de' ? 'Was kostet mein Problem? →' : 'What does my problem cost? →'}
      </a>
      <p style="font-size:0.9rem;color:var(--muted);margin:0;">
        {lang === 'de' ? 'Kein Konzernpreis. Kein Minutentakt.' : 'No corporate price. No per-minute billing.'}
      </p>
    </div>
  </div>
</section>
