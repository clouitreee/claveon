---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---
<footer class="section-sm" style="background: #F8FAFC; border-top: 1px solid var(--border);">
  <div class="container">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">

      <div class="flex items-center gap-6">
        <a href={lang === 'de' ? '/impressum' : '/en/impressum'}
          class="text-sm hover:underline" style="color: var(--muted); text-decoration: none;">
          Impressum
        </a>
        <a href={lang === 'de' ? '/datenschutz' : '/en/datenschutz'}
          class="text-sm hover:underline" style="color: var(--muted); text-decoration: none;">
          Datenschutz
        </a>
      </div>

      <div class="flex items-center gap-4">
        <span class="text-xs font-mono" style="color: var(--muted);">
          {lang === 'de' ? 'IT für Unternehmen:' : 'IT for businesses:'}
        </span>
        <a href="https://werixo.de" target="_blank" rel="noopener"
          class="text-xs font-semibold" style="color: var(--blue); text-decoration: none;">
          werixo.de →
        </a>
      </div>

    </div>
    <p class="text-xs mt-4" style="color: #CBD5E1;">
      {lang === 'de' ? 'Keine Tracking-Cookies. Keine Datenweitergabe.' : 'No tracking cookies. No data sharing.'}
    </p>
  </div>
</footer>
