---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---
<footer style="padding:2rem 0;border-top:1px solid var(--border);background:var(--text);">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-left">
        <span style="font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:1rem;color:#fff;letter-spacing:-0.03em;">Clave<span style="color:var(--terra);">ON</span></span>
        <a href={lang === 'de' ? '/impressum/' : '/en/impressum/'} class="footer-link">Impressum</a>
        <a href={lang === 'de' ? '/datenschutz/' : '/en/datenschutz/'} class="footer-link">Datenschutz</a>
      </div>
      <div class="footer-werixo">
        <span style="font-size:0.8rem;color:#6B7280;">{lang === 'de' ? 'IT für Unternehmen:' : 'IT for businesses:'}</span>
        <a href="https://werixo.de" target="_blank" rel="noopener" class="footer-werixo-link">WERIXO — werixo.de ↗</a>
      </div>
    </div>
    <p style="font-size:0.75rem;color:#4B5563;margin-top:1rem;margin-bottom:0;font-family:'IBM Plex Mono',monospace;">
      {lang === 'de' ? 'Ihre Daten sind sicher · Kein Tracking · Lokales Team in Köln' : 'Your data is safe · No tracking · Local team in Cologne'}
    </p>
  </div>
</footer>

<style>
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}
.footer-left {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.footer-link {
  font-size: 0.8rem;
  color: #9CA3AF;
  text-decoration: none;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
}
.footer-link:hover { color: #fff; }
.footer-werixo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.footer-werixo-link {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.85rem;
  color: var(--terra);
  text-decoration: none;
  font-weight: 700;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
}
.footer-werixo-link:hover { color: #e06030; }

@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .footer-left { gap: 1rem; }
  .footer-werixo { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
}
</style>
