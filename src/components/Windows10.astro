---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
---
<section class="section-sm" data-reveal>
  <div class="container">
    <div class="rounded-xl p-8 md:p-10" style="background: #FFFBEB; border: 1.5px solid #FDE68A;">
      <div class="flex items-start gap-4">
        <div class="text-2xl flex-shrink-0">⚠️</div>
        <div>
          <div class="inline-block text-xs font-mono tracking-widest uppercase mb-3 font-semibold" style="color: var(--amber);">
            {lang === 'de' ? 'Aktuell & wichtig' : 'Current & important'}
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-3" style="color: var(--text);">
            {lang === 'de'
              ? 'Windows 10 läuft nicht mehr — was jetzt?'
              : 'Windows 10 is no longer supported — what now?'}
          </h2>
          <p class="text-base mb-5" style="color: #92400E;">
            {lang === 'de'
              ? 'Seit Oktober 2025 erhält Windows 10 keine Sicherheitsupdates mehr von Microsoft. Millionen von PCs in Deutschland sind betroffen. Upgrade auf Windows 11, neues Gerät oder Alternative — ich berate Sie und setze es um.'
              : 'Since October 2025, Windows 10 no longer receives security updates from Microsoft. Millions of PCs in Germany are affected. Upgrade to Windows 11, new device, or alternative — I advise and implement.'}
          </p>
          <div class="flex flex-wrap gap-3">
            {(lang === 'de'
              ? ['Upgrade-Beratung', 'Windows 11 Einrichtung', 'Datenmigration zum neuen PC', 'Schritt-für-Schritt Erklärung']
              : ['Upgrade advice', 'Windows 11 setup', 'Data migration to new PC', 'Step-by-step explanation']
            ).map(item => (
              <span class="text-sm px-3 py-1 rounded-full font-medium" style="background: #FEF3C7; color: #92400E;">
                {item}
              </span>
            ))}
          </div>
          <div class="mt-6">
            <a href="#kontakt" class="btn-primary" style="background: var(--amber);">
              {lang === 'de' ? 'Jetzt beraten lassen →' : 'Get advice now →'}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<div class="divider"></div>
