---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
const otherLang = lang === 'de' ? 'en' : 'de';
const otherHref = lang === 'de' ? '/en/' : '/';
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100">
  <div class="container">
    <div class="flex h-14 items-center justify-between">

      <a href={lang === 'de' ? '/' : '/en/'} class="font-bold text-lg tracking-tight" style="color: var(--text); text-decoration: none;">
        Clave<span style="color: var(--blue);">ON</span>
      </a>

      <div class="flex items-center gap-5">
        <a
          href={otherHref}
          class="font-mono text-xs tracking-widest uppercase"
          style="color: var(--muted); text-decoration: none;"
        >
          {otherLang}
        </a>
        <span class="text-slate-200 select-none">|</span>
        <a
          href="https://werixo.de"
          target="_blank"
          rel="noopener"
          class="hidden sm:inline text-xs font-medium"
          style="color: var(--muted); text-decoration: none;"
        >
          {lang === 'de' ? 'Für Unternehmen →' : 'For businesses →'}
        </a>
      </div>

    </div>
  </div>
</nav>
<!-- Spacer -->
<div class="h-14"></div>
