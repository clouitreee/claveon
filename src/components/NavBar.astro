---
interface Props { lang?: string; }
const { lang = 'de' } = Astro.props;
const otherHref = lang === 'de' ? '/en/' : '/';
const otherFlag = lang === 'de' ? '🇬🇧' : '🇩🇪';
const otherLabel = lang === 'de' ? 'EN' : 'DE';
---
<nav class="fixed top-0 left-0 right-0 z-50" style="background:rgba(255,255,255,0.97);backdrop-filter:blur(8px);border-bottom:1px solid var(--border);">
  <div class="container">
    <div class="flex h-16 items-center justify-between">
      <a href={lang === 'de' ? '/' : '/en/'} style="text-decoration:none;display:flex;align-items:baseline;">
        <span style="font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:1.25rem;color:var(--text);letter-spacing:-0.04em;">Clave</span><span style="font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:1.25rem;color:var(--terra);letter-spacing:-0.04em;">ON</span>
      </a>
      <div class="flex items-center gap-5">
        <a href={otherHref} style="font-family:'IBM Plex Mono',monospace;font-size:0.8rem;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:0.35rem;">{otherFlag} {otherLabel}</a>
        <span style="width:1px;height:1rem;background:var(--border);display:inline-block;"></span>
        <a href="https://werixo.de" target="_blank" rel="noopener" style="font-family:'IBM Plex Mono',monospace;font-size:0.75rem;color:var(--muted);text-decoration:none;white-space:nowrap;">
          {lang === 'de' ? 'Für Unternehmen ↗' : 'For businesses ↗'}
        </a>
      </div>
    </div>
  </div>
</nav>
<div style="height:4rem;"></div>
