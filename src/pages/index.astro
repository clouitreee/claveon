---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import BrandTicker from '../components/BrandTicker.astro';
import Services from '../components/Services.astro';
import Pakete from '../components/Pakete.astro';
import UeberMartin from '../components/UeberMartin.astro';
import Kontakt from '../components/Kontakt.astro';
import WerixoBridge from '../components/WerixoBridge.astro';
import Footer from '../components/Footer.astro';
const lang = 'de';
---
<Layout
  title="PC langsam? WLAN weg? Jemand kommt zu Ihnen – Köln ab €29 | ClaveON"
  description="PC läuft langsam, WLAN geht nicht, Handy einrichten? Wir kommen zu Ihnen – Ehrenfeld, Nippes, Sülz, Lindenthal & ganz Köln. Fernwartung €29 · Vor Ort €79. Kein Konzernpreis. Antwort in 24h."
  lang={lang} canonicalPath="/">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://claveon.de/#business",
    "name": "ClaveON Technikhilfe Köln",
    "description": "Persönliche Technikhilfe in Köln — PC-Reparatur, WLAN einrichten, Smartphone-Hilfe, Drucker & TV. Fernwartung ab €29, Vor-Ort ab €79. Kein Konzernpreis, kein Minutentakt.",
    "url": "https://claveon.de/",
    "email": "info@claveon.de",
    "image": "https://claveon.de/assets/og-image.jpg",
    "priceRange": "€29–€99",
    "currenciesAccepted": "EUR",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Köln",
      "addressRegion": "Nordrhein-Westfalen",
      "postalCode": "50823",
      "addressCountry": "DE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 50.9333,
      "longitude": 6.9500
    },
    "areaServed": [
      {"@type":"City","name":"Köln"},
      {"@type":"City","name":"Hürth"},
      {"@type":"City","name":"Frechen"},
      {"@type":"City","name":"Pulheim"},
      {"@type":"City","name":"Leverkusen"},
      {"@type":"City","name":"Bergisch Gladbach"},
      {"@type":"City","name":"Dormagen"},
      {"@type":"City","name":"Brühl"}
    ],
    "knowsLanguage": ["de","es","en"],
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Technikhilfe Leistungen",
      "itemListElement": [
        {"@type":"Offer","name":"Fernwartung","description":"Remote-Hilfe per Bildschirmübertragung, 30 Minuten","price":"29","priceCurrency":"EUR"},
        {"@type":"Offer","name":"Vor-Ort Hilfe","description":"Persönlicher Besuch in Köln & 15 km Umgebung, ca. 1 Stunde","price":"79","priceCurrency":"EUR"},
        {"@type":"Offer","name":"Neustart-Paket","description":"Neues Gerät einrichten, Daten übertragen, WLAN verbinden","price":"89","priceCurrency":"EUR"},
        {"@type":"Offer","name":"Windows 10 auf 11 Migration","description":"Upgrade oder Neueinrichtung inkl. Datenmigration","price":"99","priceCurrency":"EUR"}
      ]
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Mein PC läuft langsam – was kann ich tun?","acceptedAnswer":{"@type":"Answer","text":"Ein langsamer PC lässt sich oft per Fernwartung beheben. Wir verbinden uns mit Ihrem Bildschirm und bereinigen das System — für €29 / 30 Minuten, ohne dass Sie irgendwo hinfahren müssen."}},
      {"@type":"Question","name":"WLAN geht nicht mehr – wer kann helfen in Köln?","acceptedAnswer":{"@type":"Answer","text":"Wir kommen zu Ihnen nach Köln und richten WLAN und Router neu ein. Ein Vor-Ort-Einsatz kostet €79. Bei einfachen Problemen reicht oft auch eine Fernwartung für €29."}},
      {"@type":"Question","name":"Wer kommt nach Hause und repariert den Computer in Köln?","acceptedAnswer":{"@type":"Answer","text":"ClaveON kommt persönlich zu Ihnen — in alle Kölner Stadtteile (Ehrenfeld, Nippes, Sülz, Lindenthal, Deutz, Mülheim, Rodenkirchen, Chorweiler u.v.m.) sowie 15 km Umgebung. Vor-Ort-Einsatz ab €79."}},
      {"@type":"Question","name":"Neues Handy einrichten lassen in Köln – was kostet das?","acceptedAnswer":{"@type":"Answer","text":"Wir richten Ihr neues Smartphone ein, übertragen Kontakte, Fotos und Apps. Ein Vor-Ort-Einsatz kostet €79, ein komplettes Neustart-Paket (neues Gerät + Datenmigration) €89."}},
      {"@type":"Question","name":"Drucker funktioniert nicht – können Sie das beheben?","acceptedAnswer":{"@type":"Answer","text":"Ja, wir kommen zu Ihnen und richten den Drucker neu ein oder beheben den Fehler. Vor-Ort-Einsatz €79, Köln & 15 km Umgebung."}},
      {"@type":"Question","name":"Windows 10 läuft aus – wie wechsle ich auf Windows 11?","acceptedAnswer":{"@type":"Answer","text":"Wir übernehmen das komplette Upgrade auf Windows 11 oder richten ein neues Gerät ein — inklusive Datenmigration und Erklärung für €99."}},
      {"@type":"Question","name":"Wie schnell kommt jemand zu mir nach Köln?","acceptedAnswer":{"@type":"Answer","text":"Wir antworten innerhalb von 24 Stunden und vereinbaren dann einen Termin. Kein Callcenter, direkte Kommunikation."}}
    ]
  })} />
  <NavBar lang={lang} />
  <main id="main-content">
    <Hero lang={lang} />
    <TrustBar lang={lang} />
    <BrandTicker />
    <Services lang={lang} />
    <Pakete lang={lang} />
    <UeberMartin lang={lang} />
    <Kontakt lang={lang} />
  </main>
  <WerixoBridge lang={lang} />
  <Footer lang={lang} />
</Layout>
