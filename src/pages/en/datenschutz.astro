---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
---
<Layout title="Privacy Policy | ClaveON" description="Privacy Policy ClaveON" lang="en" canonicalPath="/en/datenschutz">
  <NavBar lang="en" />
  <main class="section">
    <div class="container" style="max-width: 680px;">
      <h1 class="text-3xl font-bold mb-8">Privacy Policy</h1>
      <div class="space-y-6 text-base leading-relaxed" style="color: var(--muted);">
        <div>
          <p class="font-semibold mb-1" style="color: var(--text);">Responsible</p>
          <p>Martin Lache · Liebigstraße 7 · 50823 Cologne · Email: info@claveon.de</p>
        </div>
        <div>
          <p class="font-semibold mb-1" style="color: var(--text);">Data collected</p>
          <p>We only store data you voluntarily submit via the contact form (name, email, message), used exclusively to respond to your request.</p>
        </div>
        <div>
          <p class="font-semibold mb-1" style="color: var(--text);">Contact form</p>
          <p>Messages are processed via Resend (resend.com) and delivered by email. No permanent storage.</p>
        </div>
        <div>
          <p class="font-semibold mb-1" style="color: var(--text);">Hosting</p>
          <p>This website is hosted on Cloudflare Pages. Technical access data (e.g. IP address) may be processed.</p>
        </div>
        <div>
          <p class="font-semibold mb-1" style="color: var(--text);">Cookies & Tracking</p>
          <p>No tracking cookies. No analytics. No data sharing with third parties.</p>
        </div>
        <div>
          <p class="font-semibold mb-1" style="color: var(--text);">Your rights</p>
          <p>Access, correction, deletion per GDPR. Contact: <a href="mailto:info@claveon.de" style="color: var(--blue);">info@claveon.de</a></p>
        </div>
      </div>
    </div>
  </main>
  <Footer lang="en" />
</Layout>
