  description="On-site tech help in Cologne: PC, WiFi, smartphone, printer, TV. Remote from €25 · On-site from €49. No per-minute billing."
  lang={lang}
  canonicalPath="/en/"
>
  <NavBar lang={lang} />
  <main>
    <Hero lang={lang} />
    <TrustBar lang={lang} />
    <Windows10 lang={lang} />
    <Services lang={lang} />
    <Pakete lang={lang} />
    <UeberMartin lang={lang} />
    <Kontakt lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
