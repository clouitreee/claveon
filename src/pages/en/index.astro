---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import BrandTicker from '../../components/BrandTicker.astro';
import Services from '../../components/Services.astro';
import Pakete from '../../components/Pakete.astro';
import UeberCarlos from '../../components/UeberCarlos.astro';
import Kontakt from '../../components/Kontakt.astro';
import WerixoBridge from '../../components/WerixoBridge.astro';
import Footer from '../../components/Footer.astro';
const lang = 'en';
---
<Layout
  title="PC slow? WiFi down? Someone comes to you – Cologne from €29 | ClaveON"
  description="PC running slow, WiFi not working, new phone setup? We come to you in Cologne – Ehrenfeld, Nippes, Sülz & all districts. Remote €29 · On-site €79. No corporate pricing. Reply within 24h."
  lang={lang} canonicalPath="/en/">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://claveon.de/#business",
    "name": "ClaveON Tech Help Cologne",
    "description": "Personal tech help in Cologne — PC repair, WiFi setup, smartphone help, printer & TV. Remote from €29, on-site from €79. No corporate pricing, no per-minute billing.",
    "url": "https://claveon.de/en/",
    "email": "info@claveon.de",
    "image": "https://claveon.de/assets/og-image.jpg",
    "priceRange": "€29–€99",
    "currenciesAccepted": "EUR",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cologne",
      "addressRegion": "North Rhine-Westphalia",
      "postalCode": "50823",
      "addressCountry": "DE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 50.9333,
      "longitude": 6.9500
    },
    "areaServed": [
      {"@type":"City","name":"Cologne"},
      {"@type":"City","name":"Hürth"},
      {"@type":"City","name":"Frechen"},
      {"@type":"City","name":"Pulheim"},
      {"@type":"City","name":"Leverkusen"},
      {"@type":"City","name":"Bergisch Gladbach"},
      {"@type":"City","name":"Dormagen"},
      {"@type":"City","name":"Brühl"}
    ],
    "knowsLanguage": ["de","es","en"],
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Tech Help Services",
      "itemListElement": [
        {"@type":"Offer","name":"Remote Support","description":"Screen sharing help, 30 minutes","price":"29","priceCurrency":"EUR"},
        {"@type":"Offer","name":"On-site Help","description":"Personal visit in Cologne & 15 km area, approx. 1 hour","price":"79","priceCurrency":"EUR"},
        {"@type":"Offer","name":"Fresh Start Package","description":"Set up new device, transfer data, connect WiFi","price":"89","priceCurrency":"EUR"},
        {"@type":"Offer","name":"Windows 10 to 11 Migration","description":"Upgrade or fresh setup including data migration","price":"99","priceCurrency":"EUR"}
      ]
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"My PC is running slow – what can I do?","acceptedAnswer":{"@type":"Answer","text":"A slow PC can often be fixed remotely. We connect to your screen and clean up the system for €29 / 30 minutes — no need to go anywhere."}},
      {"@type":"Question","name":"WiFi not working – who can help in Cologne?","acceptedAnswer":{"@type":"Answer","text":"We come to you in Cologne and set up your WiFi and router. An on-site visit costs €79. For simple problems, remote help at €29 is often enough."}},
      {"@type":"Question","name":"Who comes to my home to fix my computer in Cologne?","acceptedAnswer":{"@type":"Answer","text":"ClaveON comes to you personally — all Cologne districts (Ehrenfeld, Nippes, Sülz, Lindenthal, Deutz, Mülheim, Rodenkirchen and more) and 15 km surroundings. On-site from €79."}},
      {"@type":"Question","name":"Can you set up my new phone in Cologne?","acceptedAnswer":{"@type":"Answer","text":"We set up your new smartphone, transfer contacts, photos and apps. On-site visit €79, full Fresh Start package (new device + data transfer) €89."}},
      {"@type":"Question","name":"Printer not working – can you fix it?","acceptedAnswer":{"@type":"Answer","text":"Yes, we come to you and reinstall or fix the printer. On-site visit €79, Cologne & 15 km area."}},
      {"@type":"Question","name":"Windows 10 is ending – how do I switch to Windows 11?","acceptedAnswer":{"@type":"Answer","text":"We handle the full upgrade to Windows 11 or set up a new device — including data migration and explanation for €99."}},
      {"@type":"Question","name":"How quickly can someone come to me in Cologne?","acceptedAnswer":{"@type":"Answer","text":"We reply within 24 hours and then arrange an appointment. No call centre — direct communication with the technician."}}
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Tech Help Services in Cologne",
    "itemListElement": [
      {"@type":"ListItem","position":1,"item":{"@type":"Service","name":"PC & Laptop Repair","description":"Diagnostics, cleanup, system recovery — Remote €29 / On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":2,"item":{"@type":"Service","name":"iPhone & Android Help","description":"Smartphone setup, data transfer, app troubleshooting — On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":3,"item":{"@type":"Service","name":"WiFi & Router Setup","description":"WiFi setup, signal optimization, mesh configuration — Remote €29 / On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":4,"item":{"@type":"Service","name":"Smart TV & Streaming Setup","description":"TV setup, streaming apps, picture & sound optimization — On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":5,"item":{"@type":"Service","name":"Printer & Scanner Help","description":"Printer installation, wireless printing, scanner setup — On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":6,"item":{"@type":"Service","name":"Coffee Machine & Smart Devices","description":"Smart coffee machine, robot vacuum, IoT device setup — On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":7,"item":{"@type":"Service","name":"Smart Home & Robot Vacuum","description":"Smart home device configuration, automation setup — On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":8,"item":{"@type":"Service","name":"Passwords & Email Help","description":"Email setup, password manager configuration, account recovery — Remote €29","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":9,"item":{"@type":"Service","name":"Photos & Backup","description":"Photo backup, cloud storage setup, backup configuration — Remote €29 / On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":10,"item":{"@type":"Service","name":"Windows 10 → 11 Migration","description":"Windows upgrade or fresh setup including data migration — €99","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}},
      {"@type":"ListItem","position":11,"item":{"@type":"Service","name":"VR & Mixed Reality","description":"VR headset setup, software configuration, room setup — On-site €79","provider":{"@id":"https://claveon.de/#business"},"areaServed":{"@type":"City","name":"Cologne"}}}
    ]
  })} />
  <NavBar lang={lang} />
  <main id="main-content">
    <Hero lang={lang} />
    <TrustBar lang={lang} />
    <BrandTicker />
    <Services lang={lang} />
    <Pakete lang={lang} />
    <UeberCarlos lang={lang} />
    <Kontakt lang={lang} />
  </main>
  <WerixoBridge lang={lang} />
  <Footer lang={lang} />
</Layout>
